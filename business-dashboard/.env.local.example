# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ── Airtable ──
# Personal Access Token from https://airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=pat_replace_me

# Base ID for the "Business Dashboard" base. Find it under
# https://airtable.com/api or the URL of your base (starts with "app...").
AIRTABLE_BASE_ID=app_replace_me

# ── Optional: Clerk auth (currently unused; re-enable when wiring auth) ──
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# CLERK_SECRET_KEY=sk_test_replace_me
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Optional: Resend (Phase 5 — invoice email) ──
# RESEND_API_KEY=re_replace_me
